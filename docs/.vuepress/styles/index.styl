// Identical to .sidebar-heading but with !important to
// fix the cursor being replaced for closed dates.

.sidebar-heading {
    color: #2c3e50;
    transition: color .15s ease;
    cursor: pointer !important;
    font-size: 1.1em;
    font-weight: 700;
    padding: .35rem 1.5rem .35rem 1.25rem;
    width: 100%;
    box-sizing: border-box;
    margin: 0;
    border-left: .25rem solid transparent;
}
